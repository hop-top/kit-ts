{
  "name": "@hop-top/kit",
  "version": "0.5.0-alpha.1",
  "description": "Shared CLI utilities for hop-top tools — TypeScript/CJS edition",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "require": "./dist/cli.js",
      "default": "./dist/cli.js"
    },
    "./output": {
      "types": "./dist/output.d.ts",
      "require": "./dist/output.js",
      "default": "./dist/output.js"
    },
    "./xdg": {
      "types": "./dist/xdg.d.ts",
      "require": "./dist/xdg.js",
      "default": "./dist/xdg.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "require": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./sqlstore": {
      "types": "./dist/sqlstore.d.ts",
      "require": "./dist/sqlstore.js",
      "default": "./dist/sqlstore.js"
    },
    "./upgrade": {
      "types": "./dist/upgrade.d.ts",
      "require": "./dist/upgrade.js",
      "default": "./dist/upgrade.js"
    },
    "./llm": {
      "types": "./dist/llm.d.ts",
      "require": "./dist/llm.js",
      "default": "./dist/llm.js"
    },
    "./routellm": {
      "types": "./dist/routellm.d.ts",
      "require": "./dist/routellm.js",
      "default": "./dist/routellm.js"
    },
    "./alias": {
      "types": "./dist/alias.d.ts",
      "require": "./dist/alias.js",
      "default": "./dist/alias.js"
    },
    "./tui": {
      "types": "./dist/tui/index.d.ts",
      "require": "./dist/tui/index.js",
      "default": "./dist/tui/index.js"
    },
    "./errcorrect": {
      "types": "./dist/errcorrect.d.ts",
      "require": "./dist/errcorrect.js",
      "default": "./dist/errcorrect.js"
    },
    "./safety": {
      "types": "./dist/safety.d.ts",
      "require": "./dist/safety.js",
      "default": "./dist/safety.js"
    },
    "./provenance": {
      "types": "./dist/provenance.d.ts",
      "require": "./dist/provenance.js",
      "default": "./dist/provenance.js"
    },
    "./stream": {
      "types": "./dist/stream.d.ts",
      "require": "./dist/stream.js",
      "default": "./dist/stream.js"
    },
    "./progress": {
      "types": "./dist/progress.d.ts",
      "require": "./dist/progress.js",
      "default": "./dist/progress.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "require": "./dist/auth.js",
      "default": "./dist/auth.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "require": "./dist/api.js",
      "default": "./dist/api.js"
    },
    "./rpc": {
      "types": "./dist/rpc.d.ts",
      "require": "./dist/rpc.js",
      "default": "./dist/rpc.js"
    },
    "./aim": {
      "types": "./dist/aim.d.ts",
      "require": "./dist/aim.js",
      "default": "./dist/aim.js"
    },
    "./scope": {
      "types": "./dist/scope.d.ts",
      "require": "./dist/scope.js",
      "default": "./dist/scope.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "require": "./dist/telemetry/index.js",
      "default": "./dist/telemetry/index.js"
    },
    "./id": {
      "types": "./dist/id/index.d.ts",
      "require": "./dist/id/index.js",
      "default": "./dist/id/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/alias.ts src/cli.ts src/output.ts src/xdg.ts src/config.ts src/sqlstore.ts src/upgrade.ts src/llm.ts src/routellm.ts src/tui/index.ts src/errcorrect.ts src/safety.ts src/provenance.ts src/stream.ts src/progress.ts src/auth.ts src/api.ts src/rpc.ts src/aim.ts src/scope.ts src/telemetry/index.ts src/id/index.ts --format cjs --dts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@clack/prompts": "^1.2.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@hop-top/cite": "^0.1.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "csv-stringify": "^6.7.0",
    "eta": "^4.6.0",
    "hono": "^4.12.10",
    "js-yaml": "^4.1.1",
    "picomatch": "^4.0.4",
    "pino": "^10.3.1",
    "semver": "^7.7.4",
    "typeid-js": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/picomatch": "^4.0.3",
    "@types/semver": "^7.7.1",
    "esbuild": "^0.25.12",
    "eslint": "^10.2.0",
    "tsup": "^8",
    "typescript": "^5",
    "typescript-eslint": "^8.58.0",
    "vitest": "^1"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
